# ===========================================
# NexusLearn Environment Configuration
# ===========================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/nexuslearn

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Email Verification (set to "true" to require email verification before sign-in)
REQUIRE_EMAIL_VERIFICATION=true

# ── OAuth Providers ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign-In (requires Apple Developer account)
# See: https://next-auth.js.org/providers/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Email / SMTP ─────────────────────────────
# For sending verification emails and password resets
# Works with Gmail, SendGrid, Resend, Mailgun, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@nexuslearn.app
FROM_NAME=NexusLearn

# ── LiveKit (WebRTC Video Conferencing) ──────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_URL=https://your-livekit-server.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# ── S3-Compatible Storage ────────────────────
# Works with AWS S3, Cloudflare R2, MinIO, Supabase Storage, etc.
S3_BUCKET=nexuslearn-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=  # Optional: for S3-compatible services like Cloudflare R2
S3_FORCE_PATH_STYLE=false  # Set to true for MinIO
S3_CDN_URL=  # Optional: CDN URL for file access

# ── YouTube (optional) ───────────────────────
YOUTUBE_API_KEY=

# ── Social Media - Twitter/X ────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ── Social Media - Facebook ─────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_APP_ID=

# ── Social Media - LinkedIn ─────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Social Media - Instagram (uses Facebook Graph API) ──
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── Stripe (Billing & Subscriptions) ────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# ── Application ──────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
