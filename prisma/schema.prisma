generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & Users
// ============================================================

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole   @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  bio           String?
  timezone      String     @default("UTC")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Auth relations
  accounts Account[]
  sessions Session[]

  // Meeting relations
  hostedMeetings        Meeting[]             @relation("MeetingHost")
  meetingParticipations MeetingParticipant[]
  meetingTranscripts    MeetingTranscript[]    @relation("TranscriptSpeaker")

  // Chat relations
  createdChannels Channel[]        @relation("ChannelCreator")
  channelMembers  ChannelMember[]
  sentMessages    Message[]        @relation("MessageSender")
  messageReactions MessageReaction[]

  // Document relations
  ownedDocuments   Document[]        @relation("DocumentOwner")
  ownedFolders     DocumentFolder[]  @relation("FolderOwner")
  documentVersions DocumentVersion[] @relation("VersionAuthor")
  documentComments DocumentComment[]

  // Task/Project relations
  ownedProjects   Project[]       @relation("ProjectOwner")
  projectMembers  ProjectMember[]
  assignedTasks   Task[]          @relation("TaskAssignee")
  reportedTasks   Task[]          @relation("TaskReporter")
  taskComments    TaskComment[]

  // Course relations
  taughtCourses Course[]     @relation("CourseInstructor")
  enrollments   Enrollment[]
  lessonProgress LessonProgress[]
  submissions   Submission[]

  // File relations
  uploadedFiles File[]       @relation("FileUploader")
  ownedFileFolders FileFolder[] @relation("FileFolderOwner")
  sharedFiles   FileShare[]  @relation("FileSharedBy")

  // Analytics
  activityLogs ActivityLog[]

  // Platform feature relations
  notifications    Notification[] @relation("UserNotifications")
  userSettings     UserSettings?  @relation("UserSettingsRel")
  adminLogs        AdminLog[]     @relation("AdminLogs")
  searchHistory    SearchHistory[] @relation("SearchHistory")

  // LMS Enhancement relations
  quizAttempts    QuizAttempt[]
  certificates    Certificate[]
  userBadges      UserBadge[]
  userPoints      UserPoints?
  leaderboards    Leaderboard[]
  forumThreads    ForumThread[]
  forumPosts      ForumPost[]
  studentGrades   StudentGrade[]
  learningPaths   LearningPath[]  @relation("LearningPathCreator")
  pathEnrollments LearningPathEnrollment[]
  attendances     Attendance[]
  announcements   Announcement[]

  // Meeting Minutes relations
  chairedMinutes    MeetingMinutes[] @relation("MinutesChairperson")
  secretaryMinutes  MeetingMinutes[] @relation("MinutesSecretary")
  minutesAttendance MinutesAttendee[]
  minutesAgendaPresenter MinutesAgendaItem[]
  movedMotions      MinutesMotion[]  @relation("MotionMover")
  secondedMotions   MinutesMotion[]  @relation("MotionSeconder")
  minutesActionItems MinutesActionItem[]
  minutesApprovals  MinutesApproval[]
  minutesAmendments MinutesAmendment[]
  minutesAttachmentUploads MinutesAttachment[]

  // Social Media relations
  socialAccounts  SocialAccount[]
  socialPosts     SocialPost[]
  socialAutoRules SocialAutoRule[]

  // Billing relations
  subscriptions     Subscription[]
  couponRedemptions CouponRedemption[]
  videoProjects     VideoProject[]
  videoCaptions     VideoCaption[]
  videoThumbnails   VideoThumbnail[]
  videoJobs         VideoProcessingJob[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String   // email address
  token      String   @unique
  type       String   @default("EMAIL_VERIFICATION") // EMAIL_VERIFICATION | PASSWORD_RESET
  expires    DateTime

  @@unique([identifier, token])
  @@index([token])
  @@index([type])
  @@map("verification_tokens")
}

// ============================================================
// Meetings / Conferencing
// ============================================================

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum ParticipantRole {
  HOST
  CO_HOST
  PRESENTER
  ATTENDEE
}

model Meeting {
  id               String        @id @default(cuid())
  title            String
  description      String?       @db.Text
  hostId           String
  scheduledStart   DateTime
  scheduledEnd     DateTime
  actualStart      DateTime?
  actualEnd        DateTime?
  status           MeetingStatus @default(SCHEDULED)
  roomId           String?       @unique
  recordingUrl     String?
  isRecurring      Boolean       @default(false)
  recurringPattern String?
  maxParticipants  Int           @default(100)
  settings         Json          @default("{}")
  webinarMode      Boolean       @default(false)
  webinarConfig    Json          @default("{}")
  dialInPin        String?
  isStreaming       Boolean       @default(false)
  streamConfig     Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  host         User                 @relation("MeetingHost", fields: [hostId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
  transcripts  MeetingTranscript[]
  recordings   MeetingRecording[]
  breakoutRooms BreakoutRoom[]
  polls        Poll[]
  analytics    MeetingAnalytics?
  attendances  Attendance[]
  minutes      MeetingMinutes[]

  @@index([hostId])
  @@index([status])
  @@index([scheduledStart])
  @@map("meetings")
}

model MeetingParticipant {
  id          String          @id @default(cuid())
  meetingId   String
  userId      String
  role        ParticipantRole @default(ATTENDEE)
  joinedAt    DateTime        @default(now())
  leftAt      DateTime?
  isHandRaised Boolean        @default(false)
  isMuted     Boolean         @default(false)
  isCameraOff Boolean         @default(false)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
  @@map("meeting_participants")
}

model MeetingTranscript {
  id         String   @id @default(cuid())
  meetingId  String
  speakerId  String
  content    String   @db.Text
  timestamp  DateTime
  language   String   @default("en")
  translation String? @db.Text
  confidence Float    @default(0)
  sentiment  String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speaker User    @relation("TranscriptSpeaker", fields: [speakerId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([speakerId])
  @@map("meeting_transcripts")
}

model MeetingRecording {
  id        String   @id @default(cuid())
  meetingId String
  url       String
  duration  Int      @default(0)
  size      BigInt   @default(0)
  format    String   @default("webm")
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_recordings")
}

model BreakoutRoom {
  id           String   @id @default(cuid())
  meetingId    String
  name         String
  participants Json     @default("[]")
  createdAt    DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("breakout_rooms")
}

enum PollType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RATING
  WORD_CLOUD
  OPEN_ENDED
}

model Poll {
  id        String   @id @default(cuid())
  meetingId String
  question  String
  type      PollType @default(SINGLE_CHOICE)
  options   Json     @default("[]")
  responses Json     @default("[]")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("polls")
}

// ============================================================
// Chat / Messaging
// ============================================================

enum ChannelType {
  PUBLIC
  PRIVATE
  DM
}

enum ChannelMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MessageType {
  TEXT
  FILE
  CODE
  SYSTEM
}

model Channel {
  id          String      @id @default(cuid())
  name        String
  description String?
  type        ChannelType @default(PUBLIC)
  workspaceId String?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  createdBy User            @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   ChannelMember[]
  messages  Message[]

  @@index([createdById])
  @@index([type])
  @@map("channels")
}

model ChannelMember {
  id        String            @id @default(cuid())
  channelId String
  userId    String
  role      ChannelMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now())
  lastRead  DateTime          @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@map("channel_members")
}

model Message {
  id        String      @id @default(cuid())
  channelId String
  senderId  String
  content   String      @db.Text
  type      MessageType @default(TEXT)
  replyToId String?
  isEdited  Boolean     @default(false)
  isPinned  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  channel     Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender      User                @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo     Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[]           @relation("MessageReplies")
  reactions   MessageReaction[]
  attachments MessageAttachment[]

  @@index([channelId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model MessageAttachment {
  id        String @id @default(cuid())
  messageId String
  fileId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([fileId])
  @@map("message_attachments")
}

// ============================================================
// Documents
// ============================================================

enum DocumentType {
  DOC
  SPREADSHEET
  PRESENTATION
  WHITEBOARD
  WIKI
}

model Document {
  id            String       @id @default(cuid())
  title         String
  content       String       @db.Text @default("")
  type          DocumentType @default(DOC)
  ownerId       String
  folderId      String?
  isTemplate    Boolean      @default(false)
  version       Int          @default(1)
  collaborators Json         @default("[]")
  settings      Json         @default("{}")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  owner    User             @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  folder   DocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  versions DocumentVersion[]
  comments DocumentComment[]

  @@index([ownerId])
  @@index([folderId])
  @@index([type])
  @@map("documents")
}

model DocumentFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  ownerId   String
  color     String?
  createdAt DateTime @default(now())

  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  DocumentFolder[] @relation("FolderHierarchy")
  owner     User             @relation("FolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([ownerId])
  @@index([parentId])
  @@map("document_folders")
}

model DocumentVersion {
  id                String   @id @default(cuid())
  documentId        String
  version           Int
  content           String   @db.Text
  changedById       String
  changeDescription String?
  createdAt         DateTime @default(now())

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  changedBy User     @relation("VersionAuthor", fields: [changedById], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentComment {
  id         String    @id @default(cuid())
  documentId String
  userId     String
  content    String    @db.Text
  position   Json?
  resolvedAt DateTime?
  replyToId  String?
  createdAt  DateTime  @default(now())

  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo  DocumentComment? @relation("CommentReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies  DocumentComment[] @relation("CommentReplies")

  @@index([documentId])
  @@index([userId])
  @@map("document_comments")
}

// ============================================================
// Tasks / Projects
// ============================================================

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?       @db.Text
  ownerId        String
  status         ProjectStatus @default(ACTIVE)
  color          String        @default("#3b82f6")
  icon           String?
  sprintDuration Int           @default(14)
  currentSprint  Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner   User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ProjectMember[]
  tasks   Task[]

  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  projectId    String
  assigneeId   String?
  reporterId   String
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  storyPoints  Int?
  labels       Json         @default("[]")
  parentTaskId String?
  sortOrder    Int          @default(0)
  courseId      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter   User             @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  parentTask Task?            @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks   Task[]           @relation("TaskHierarchy")
  course     Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  comments   TaskComment[]
  attachments TaskAttachment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([status])
  @@index([priority])
  @@index([courseId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("task_comments")
}

model TaskAttachment {
  id     String @id @default(cuid())
  taskId String
  fileId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([fileId])
  @@map("task_attachments")
}

// ============================================================
// Learning / Courses
// ============================================================

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Course {
  id           String           @id @default(cuid())
  title        String
  description  String?          @db.Text
  instructorId String
  thumbnail    String?
  category     String?
  difficulty   CourseDifficulty @default(BEGINNER)
  duration     Int              @default(0)
  price        Float            @default(0)
  isPublished  Boolean          @default(false)
  tags         Json             @default("[]")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  instructor  User           @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  enrollments Enrollment[]
  tasks       Task[]

  // LMS Enhancement relations
  certificates    Certificate[]
  leaderboards    Leaderboard[]
  forums          DiscussionForum[]
  gradeItems      GradeItem[]
  rubrics         Rubric[]
  pathSteps       LearningPathStep[]
  attendances     Attendance[]
  announcements   Announcement[]

  @@index([instructorId])
  @@index([category])
  @@index([isPublished])
  @@map("courses")
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  sortOrder   Int      @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("course_modules")
}

model Lesson {
  id        String     @id @default(cuid())
  moduleId  String
  title     String
  content   String?    @db.Text
  type      LessonType @default(TEXT)
  videoUrl  String?
  duration  Int        @default(0)
  sortOrder Int        @default(0)

  module      CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  assignments Assignment[]
  quizzes     Quiz[]

  @@index([moduleId])
  @@map("lessons")
}

model Enrollment {
  id          String           @id @default(cuid())
  courseId    String
  userId      String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@map("enrollments")
}

model LessonProgress {
  id          String               @id @default(cuid())
  lessonId    String
  userId      String
  status      LessonProgressStatus @default(NOT_STARTED)
  timeSpent   Int                  @default(0)
  completedAt DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
  @@index([lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

model Assignment {
  id          String   @id @default(cuid())
  lessonId    String
  title       String
  description String?  @db.Text
  dueDate     DateTime?
  maxScore    Int      @default(100)

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([lessonId])
  @@map("assignments")
}

model Submission {
  id           String    @id @default(cuid())
  assignmentId String
  userId       String
  content      String?   @db.Text
  fileIds      Json      @default("[]")
  score        Int?
  feedback     String?   @db.Text
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
  @@map("submissions")
}

// ============================================================
// Quizzes & Question Bank
// ============================================================

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  MATCHING
  FILL_BLANK
  CODE
}

model Quiz {
  id          String   @id @default(cuid())
  lessonId    String
  title       String
  description String?
  timeLimit   Int?     // minutes
  attempts    Int      @default(1)
  passingScore Float   @default(70)
  shuffleQuestions Boolean @default(false)
  showResults    Boolean @default(true)
  createdAt   DateTime @default(now())

  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts_rel  QuizAttempt[]

  @@index([lessonId])
  @@map("quizzes")
}

model QuizQuestion {
  id          String       @id @default(cuid())
  quizId      String
  type        QuestionType @default(MULTIPLE_CHOICE)
  question    String       @db.Text
  options     Json         @default("[]")
  correctAnswer Json       @default("\"\"")
  explanation String?      @db.Text
  points      Int          @default(1)
  sortOrder   Int          @default(0)
  tags        Json         @default("[]")
  difficulty  CourseDifficulty @default(BEGINNER)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  answers     Json     @default("[]")
  score       Float    @default(0)
  passed      Boolean  @default(false)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  timeSpent   Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

// ============================================================
// Certificates
// ============================================================

model Certificate {
  id           String   @id @default(cuid())
  userId       String
  courseId      String
  certificateNo String  @unique
  templateId   String?
  issuedAt     DateTime @default(now())
  expiresAt    DateTime?
  metadata     Json     @default("{}")
  pdfUrl       String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("certificates")
}

// ============================================================
// Gamification
// ============================================================

model Badge {
  id          String @id @default(cuid())
  name        String
  description String?
  icon        String
  criteria    Json   @default("{}")
  points      Int    @default(0)
  category    String @default("general")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model UserPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  total     Int      @default(0)
  level     Int      @default(1)
  streak    Int      @default(0)
  lastActive DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model Leaderboard {
  id        String @id @default(cuid())
  userId    String
  courseId   String?
  points    Int    @default(0)
  rank      Int    @default(0)
  period    String @default("all_time")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId, period])
  @@index([points(sort: Desc)])
  @@map("leaderboard")
}

// ============================================================
// Discussion Forums
// ============================================================

model DiscussionForum {
  id        String   @id @default(cuid())
  courseId   String
  title     String
  description String?
  isLocked  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  course Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  threads ForumThread[]

  @@index([courseId])
  @@map("discussion_forums")
}

model ForumThread {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String
  title     String
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  isResolved Boolean @default(false)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum   DiscussionForum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author  User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts   ForumPost[]

  @@index([forumId])
  @@index([authorId])
  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String   @db.Text
  isAnswer  Boolean  @default(false)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([authorId])
  @@map("forum_posts")
}

// ============================================================
// Gradebook & Rubrics
// ============================================================

model GradeItem {
  id        String  @id @default(cuid())
  courseId   String
  name      String
  category  String  @default("assignment")
  weight    Float   @default(1)
  maxScore  Float   @default(100)
  
  course Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grades StudentGrade[]

  @@index([courseId])
  @@map("grade_items")
}

model StudentGrade {
  id          String   @id @default(cuid())
  gradeItemId String
  userId      String
  score       Float?
  feedback    String?  @db.Text
  gradedAt    DateTime?
  
  gradeItem GradeItem @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gradeItemId, userId])
  @@index([gradeItemId])
  @@index([userId])
  @@map("student_grades")
}

model Rubric {
  id        String   @id @default(cuid())
  courseId   String?
  title     String
  criteria  Json     @default("[]")
  createdAt DateTime @default(now())

  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@map("rubrics")
}

// ============================================================
// Learning Paths
// ============================================================

model LearningPath {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  thumbnail   String?
  createdById String
  isPublished Boolean  @default(false)
  estimatedHours Int   @default(0)
  createdAt   DateTime @default(now())

  createdBy User               @relation("LearningPathCreator", fields: [createdById], references: [id], onDelete: Cascade)
  steps     LearningPathStep[]
  enrollments LearningPathEnrollment[]

  @@index([createdById])
  @@map("learning_paths")
}

model LearningPathStep {
  id             String   @id @default(cuid())
  learningPathId String
  courseId        String
  sortOrder      Int      @default(0)
  isRequired     Boolean  @default(true)

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([learningPathId])
  @@map("learning_path_steps")
}

model LearningPathEnrollment {
  id             String   @id @default(cuid())
  learningPathId String
  userId         String
  progress       Float    @default(0)
  enrolledAt     DateTime @default(now())
  completedAt    DateTime?

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, userId])
  @@index([learningPathId])
  @@index([userId])
  @@map("learning_path_enrollments")
}

// ============================================================
// Attendance
// ============================================================

model Attendance {
  id        String   @id @default(cuid())
  courseId   String
  meetingId  String?
  userId    String
  status    String   @default("present")
  date      DateTime @default(now())
  notes     String?

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId, date])
  @@index([courseId])
  @@index([userId])
  @@map("attendance")
}

// ============================================================
// Announcements
// ============================================================

model Announcement {
  id        String   @id @default(cuid())
  courseId   String
  authorId  String
  title     String
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([authorId])
  @@map("announcements")
}

// ============================================================
// Files
// ============================================================

enum FileParentType {
  MESSAGE
  DOCUMENT
  TASK
  COURSE
  SUBMISSION
}

enum FilePermission {
  VIEW
  EDIT
  ADMIN
}

model File {
  id           String         @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         BigInt         @default(0)
  url          String
  key          String         @unique
  uploadedById String
  folderId     String?
  parentType   FileParentType?
  parentId     String?
  createdAt    DateTime       @default(now())

  uploadedBy         User                @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  folder             FileFolder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messageAttachments MessageAttachment[]
  taskAttachments    TaskAttachment[]
  shares             FileShare[]

  @@index([uploadedById])
  @@index([folderId])
  @@index([parentType, parentId])
  @@map("files")
}

model FileFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  ownerId   String
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())

  parent   FileFolder?  @relation("FileFolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children FileFolder[] @relation("FileFolderHierarchy")
  owner    User         @relation("FileFolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  files    File[]

  @@index([ownerId])
  @@index([parentId])
  @@map("file_folders")
}

model FileShare {
  id         String         @id @default(cuid())
  fileId     String
  sharedWith String
  permission FilePermission @default(VIEW)
  sharedById String
  createdAt  DateTime       @default(now())

  file     File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sharedBy User @relation("FileSharedBy", fields: [sharedById], references: [id], onDelete: Cascade)

  @@unique([fileId, sharedWith])
  @@index([fileId])
  @@index([sharedWith])
  @@map("file_shares")
}

// ============================================================
// Analytics
// ============================================================

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model MeetingAnalytics {
  id                String   @id @default(cuid())
  meetingId         String   @unique
  totalParticipants Int      @default(0)
  peakParticipants  Int      @default(0)
  avgDuration       Int      @default(0)
  engagementScore   Float    @default(0)
  createdAt         DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_analytics")
}

// ============================================================
// Notifications
// ============================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type        String   // meeting_invite, chat_message, task_assigned, etc.
  title       String
  body        String
  link        String?
  priority    String   @default("normal") // low, normal, high, urgent
  read        Boolean  @default(false)
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// User Settings
// ============================================================

model UserSettings {
  id                  String  @id @default(cuid())
  userId              String  @unique
  user                User    @relation("UserSettingsRel", fields: [userId], references: [id], onDelete: Cascade)
  theme               String  @default("system")
  accentColor         String  @default("#6366f1")
  fontSize            String  @default("medium")
  compactMode         Boolean @default(false)
  reducedMotion       Boolean @default(false)
  highContrast        Boolean @default(false)
  language            String  @default("en")
  timezone            String  @default("UTC")
  dateFormat          String  @default("MM/DD/YYYY")
  profileVisibility   String  @default("public")
  showActivityStatus  Boolean @default(true)
  showReadReceipts    Boolean @default(true)
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(true)
  inAppNotifications  Boolean @default(true)
  defaultCamera       String?
  defaultMic          String?
  defaultSpeaker      String?
  autoVirtualBg       Boolean @default(false)
  autoEyeContact      Boolean @default(false)
  twoFactorEnabled    Boolean @default(false)
  twoFactorSecret     String?
  backupCodes         Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_settings")
}

// ============================================================
// Admin
// ============================================================

model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  admin       User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)
  action      String
  target      String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}

model PlatformSettings {
  id              String  @id @default(cuid())
  key             String  @unique
  value           Json
  category        String  @default("general")
  description     String?
  updatedAt       DateTime @updatedAt

  @@map("platform_settings")
}

// ============================================================
// Search History
// ============================================================

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("SearchHistory", fields: [userId], references: [id], onDelete: Cascade)
  query     String
  category  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("search_history")
}

// ============================================================
// Meeting Minutes & Proceedings
// ============================================================

model MeetingMinutes {
  id              String   @id @default(cuid())
  meetingId       String?
  meeting         Meeting? @relation(fields: [meetingId], references: [id])
  title           String
  meetingType     String   @default("general")
  meetingNumber   String?
  organization    String?
  location        String?
  callToOrder     DateTime?
  adjournment     DateTime?
  chairpersonId   String
  chairperson     User     @relation("MinutesChairperson", fields: [chairpersonId], references: [id])
  secretaryId     String?
  secretary       User?    @relation("MinutesSecretary", fields: [secretaryId], references: [id])
  status          String   @default("draft")
  quorumRequired  Int?
  quorumPresent   Int?
  quorumMet       Boolean  @default(false)
  openingRemarks  String?  @db.Text
  closingRemarks  String?  @db.Text
  nextMeetingDate DateTime?
  nextMeetingLocation String?
  pdfUrl          String?
  signedPdfUrl    String?
  aiGenerated     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendees       MinutesAttendee[]
  agendaItems     MinutesAgendaItem[]
  motions         MinutesMotion[]
  actionItems     MinutesActionItem[]
  approvals       MinutesApproval[]
  amendments      MinutesAmendment[]
  attachments     MinutesAttachment[]

  @@index([meetingId])
  @@index([chairpersonId])
  @@index([status])
  @@index([meetingType])
}

model MinutesAttendee {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  role        String   @default("member")
  designation String?
  organization String?
  status      String   @default("present")
  arrivalTime DateTime?
  departureTime DateTime?
  proxy       String?

  @@index([minutesId])
}

model MinutesAgendaItem {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  orderNumber Int
  title       String
  description String?  @db.Text
  discussion  String?  @db.Text
  decision    String?  @db.Text
  presenterId String?
  presenter   User?    @relation(fields: [presenterId], references: [id])
  duration    Int?
  status      String   @default("pending")
  isConfidential Boolean @default(false)
  attachments String?  @db.Text

  motions     MinutesMotion[]
  actionItems MinutesActionItem[]

  @@index([minutesId])
}

model MinutesMotion {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  agendaItemId String?
  agendaItem  MinutesAgendaItem? @relation(fields: [agendaItemId], references: [id])
  motionNumber String?
  type        String   @default("resolution")
  title       String
  text        String   @db.Text
  movedById   String?
  movedBy     User?    @relation("MotionMover", fields: [movedById], references: [id])
  secondedById String?
  secondedBy  User?    @relation("MotionSeconder", fields: [secondedById], references: [id])
  result      String   @default("pending")
  votesFor    Int      @default(0)
  votesAgainst Int     @default(0)
  votesAbstain Int     @default(0)
  isUnanimous Boolean  @default(false)
  remarks     String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([minutesId])
  @@index([agendaItemId])
}

model MinutesActionItem {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  agendaItemId String?
  agendaItem  MinutesAgendaItem? @relation(fields: [agendaItemId], references: [id])
  description String   @db.Text
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  assigneeName String?
  dueDate     DateTime?
  priority    String   @default("medium")
  status      String   @default("pending")
  completedAt DateTime?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([minutesId])
  @@index([assigneeId])
  @@index([status])
}

model MinutesApproval {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  role        String
  status      String   @default("pending")
  comments    String?  @db.Text
  signatureUrl String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([minutesId, userId])
  @@index([minutesId])
}

model MinutesAmendment {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  section     String
  originalText String  @db.Text
  amendedText String   @db.Text
  reason      String?  @db.Text
  status      String   @default("proposed")
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([minutesId])
}

model MinutesAttachment {
  id          String   @id @default(cuid())
  minutesId   String
  minutes     MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  description String?
  uploadedById String
  uploadedBy  User     @relation(fields: [uploadedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([minutesId])
}

// ============================================================
// Social Media
// ============================================================

enum SocialPlatform {
  TWITTER
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  YOUTUBE
  TIKTOK
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum PostType {
  MANUAL
  AUTO_COURSE_LAUNCH
  AUTO_WEBINAR
  AUTO_CERTIFICATE
  AUTO_RECORDING
  SHARE
}

enum AutoTrigger {
  COURSE_PUBLISHED
  WEBINAR_SCHEDULED
  MEETING_RECORDED
  CERTIFICATE_EARNED
  MILESTONE_REACHED
  EVENT_REMINDER
}

model SocialAccount {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform      SocialPlatform
  platformId    String
  username      String
  displayName   String?
  avatarUrl     String?
  accessToken   String
  refreshToken  String?
  tokenExpiry   DateTime?
  scopes        String[]
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  posts         SocialPost[]
  analytics     SocialAnalytics[]

  @@unique([userId, platform, platformId])
  @@index([userId])
  @@map("social_accounts")
}

model SocialPost {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       String
  account         SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content         String
  mediaUrls       String[]
  hashtags        String[]
  status          PostStatus    @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  platformPostId  String?
  platformUrl     String?
  errorMessage    String?
  postType        PostType      @default(MANUAL)
  sourceType      String?
  sourceId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  analytics       SocialAnalytics[]

  @@index([userId])
  @@index([accountId])
  @@index([status])
  @@index([scheduledAt])
  @@map("social_posts")
}

model SocialAnalytics {
  id             String        @id @default(cuid())
  postId         String
  post           SocialPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  impressions    Int           @default(0)
  reach          Int           @default(0)
  likes          Int           @default(0)
  comments       Int           @default(0)
  shares         Int           @default(0)
  clicks         Int           @default(0)
  engagementRate Float         @default(0)
  fetchedAt      DateTime      @default(now())

  @@index([postId])
  @@index([accountId])
  @@map("social_analytics")
}

model SocialAutoRule {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  trigger       AutoTrigger
  platforms     SocialPlatform[]
  templateText  String
  includeMedia  Boolean          @default(true)
  isActive      Boolean          @default(true)
  lastTriggered DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([trigger])
  @@map("social_auto_rules")
}

// ============================================================
// Billing & Subscriptions
// ============================================================

model Plan {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String
  monthlyPrice    Float     @default(0)
  yearlyPrice     Float     @default(0)
  currency        String    @default("USD")
  stripePriceIdMonthly  String?
  stripePriceIdYearly   String?
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false)
  sortOrder       Int       @default(0)
  features        PlanFeature[]
  limits          PlanLimit[]
  subscriptions   Subscription[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("plans")
}

model PlanFeature {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature   String
  enabled   Boolean  @default(false)
  metadata  Json?

  @@unique([planId, feature])
  @@map("plan_features")
}

model PlanLimit {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  limitKey  String
  value     Float

  @@unique([planId, limitKey])
  @@map("plan_limits")
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  PAUSED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id])
  status                SubscriptionStatus @default(ACTIVE)
  billingCycle          BillingCycle       @default(MONTHLY)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  canceledAt            DateTime?
  trialEndsAt           DateTime?
  quantity              Int                @default(1)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  invoices              Invoice[]
  usageRecords          UsageRecord[]

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  VOID
}

model Invoice {
  id                  String        @id @default(cuid())
  subscriptionId      String
  subscription        Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeInvoiceId     String?       @unique
  amount              Float
  currency            String        @default("USD")
  status              InvoiceStatus @default(PENDING)
  paidAt              DateTime?
  invoiceUrl          String?
  invoicePdf          String?
  periodStart         DateTime
  periodEnd           DateTime
  createdAt           DateTime      @default(now())

  @@index([subscriptionId])
  @@map("invoices")
}

model UsageRecord {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  metric          String
  value           Float
  period          DateTime
  recordedAt      DateTime     @default(now())

  @@index([subscriptionId, metric])
  @@map("usage_records")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountType    DiscountType
  discountValue   Float
  currency        String?   @default("USD")
  maxRedemptions  Int?
  timesRedeemed   Int       @default(0)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  applicablePlans String[]
  stripeCouponId  String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  redemptions     CouponRedemption[]
  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appliedAt DateTime @default(now())

  @@unique([couponId, userId])
  @@map("coupon_redemptions")
}

// ============================================================
// Video Studio Models
// ============================================================

enum VideoProjectType {
  TEXT_TO_VIDEO
  EDITED
  TEMPLATE
  RECORDING
}

enum VideoProjectStatus {
  DRAFT
  PROCESSING
  RENDERING
  COMPLETED
  FAILED
}

model VideoProject {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  type            VideoProjectType    @default(TEXT_TO_VIDEO)
  status          VideoProjectStatus  @default(DRAFT)
  aspectRatio     String              @default("16:9")
  resolution      String              @default("1080p")
  fps             Int                 @default(30)
  duration        Float               @default(0)
  scenes          Json?
  outputUrl       String?
  thumbnailUrl    String?
  voiceoverUrl    String?
  musicTrackId    String?
  branding        Json?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  videoScenes     VideoScene[]
  captions        VideoCaption[]
  thumbnails      VideoThumbnail[]

  @@index([userId])
  @@map("video_projects")
}

model VideoScene {
  id                  String    @id @default(cuid())
  projectId           String
  project             VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order               Int
  duration            Float
  transition          String    @default("fade")
  transitionDuration  Float     @default(0.5)
  backgroundColor     String    @default("#1a1a2e")
  backgroundMediaUrl  String?
  backgroundMediaType String?
  elements            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([projectId])
  @@map("video_scenes")
}

model VideoCaption {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String?
  project       VideoProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  videoUrl      String
  language      String    @default("en")
  entries       Json
  srt           String?   @db.Text
  vtt           String?   @db.Text
  style         Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@map("video_captions")
}

model VideoThumbnail {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     VideoProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  url         String
  width       Int
  height      Int
  format      String    @default("png")
  style       String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("video_thumbnails")
}

model VideoTemplate {
  id                  String    @id @default(cuid())
  name                String
  description         String?
  category            String
  thumbnail           String?
  duration            Float
  aspectRatio         String    @default("16:9")
  scenes              Json
  customizableFields  Json?
  isPublic            Boolean   @default(true)
  usageCount          Int       @default(0)
  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("video_templates")
}

model VideoProcessingJob {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  operation   String
  inputUrl    String?
  outputUrl   String?
  status      String    @default("pending")
  progress    Int       @default(0)
  error       String?
  metadata    Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("video_processing_jobs")
}
